import os
import requests
import json

API_KEY = os.getenv("UNITYSVC_API_KEY")
BASE_URL = os.getenv("UNITYSVC_BASE_URL")  # e.g. https://api.anthropic.com
MODEL = "{{offering.name}}"  # replace if needed

url = f"{BASE_URL}/v1/messages"

headers = {
    "x-api-key": API_KEY,
    "anthropic-version": "2023-06-01",
    "content-type": "application/json"
}

# ---- Tool Implementation ----

def echo_message(message: str) -> str:
    return f"Echo: {message}"

# ---- Tool Definition for Model ----

tools = [
    {
        "name": "echo_message",
        "description": "Echoes back the given message",
        "input_schema": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "description": "The message to echo"
                }
            },
            "required": ["message"]
        }
    }
]

# ---- Step 1: Initial Request ----

payload = {
    "model": MODEL,
    "max_tokens": 300,
    "tools": tools,
    "messages": [
        {
            "role": "user",
            "content": "Call the echo_message tool with the message 'This is a test'"
        }
    ]
}

response = requests.post(url, headers=headers, json=payload)

print("Status:", response.status_code)
data = response.json()
print(json.dumps(data, indent=2))

# ---- Step 2: Detect Tool Call ----

tool_call = None

for block in data.get("content", []):
    if block.get("type") == "tool_use":
        tool_call = block
        break

if tool_call:
    print("\nTool requested:", tool_call["name"])
    print("With input:", tool_call["input"])

    # ---- Step 3: Execute Tool ----
    tool_result = echo_message(**tool_call["input"])
    print("Tool result:", tool_result)

    # ---- Step 4: Send Tool Result Back ----

    second_payload = {
        "model": MODEL,
        "max_tokens": 300,
        "messages": [
            {
                "role": "user",
                "content": "Call the echo_message tool with the message 'This is a test'"
            },
            {
                "role": "assistant",
                "content": data["content"]
            },
            {
                "role": "user",
                "content": [
                    {
                        "type": "tool_result",
                        "tool_use_id": tool_call["id"],
                        "content": tool_result
                    }
                ]
            }
        ]
    }

    final_response = requests.post(url, headers=headers, json=second_payload)
    final_data = final_response.json()

    print("\nFinal Response:")
    print(json.dumps(final_data, indent=2))

    for block in final_data.get("content", []):
        if block.get("type") == "text":
            print("\nAssistant says:")
            print(block["text"])

else:
    print("\nNo tool call triggered.")
    for block in data.get("content", []):
        if block.get("type") == "text":
            print(block["text"])